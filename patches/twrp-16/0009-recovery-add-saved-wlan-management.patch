+int GUIAction::wlanlistsaved(std::string arg __unused) {
+    GUIBorderedLogBox* logBox = FindWlanLogBox();
+    std::vector<GUIWlanList::WlanItem> wlanList;
+    std::string output = run_command_get_output(
+            "wpa_cli -iwlan0 -p/tmp/recovery/sockets list_networks");
+    std::istringstream stream(output);
+    std::string line;
+    bool header = true;
+
+    auto decode_hex_escaped = [](const std::string& value) {
+        std::string decoded;
+        for (size_t i = 0; i < value.size();) {
+            if (i + 3 < value.size() && value[i] == '\\' && value[i + 1] == 'x') {
+                auto hex_value = [](char c) {
+                    if (c >= '0' && c <= '9') return c - '0';
+                    if (c >= 'a' && c <= 'f') return 10 + c - 'a';
+                    if (c >= 'A' && c <= 'F') return 10 + c - 'A';
+                    return -1;
+                };
+                int high = hex_value(value[i + 2]);
+                int low = hex_value(value[i + 3]);
+                if (high >= 0 && low >= 0) {
+                    decoded.push_back(static_cast<char>((high << 4) | low));
+                    i += 4;
+                    continue;
+                }
+            }
+            decoded.push_back(value[i++]);
+        }
+        return decoded;
+    };
+
+    while (std::getline(stream, line)) {
+        if (header) {
+            header = false;
+            continue;
+        }
+        while (!line.empty() && line.back() == '\r') line.pop_back();
+        size_t tab1 = line.find('\t');
+        size_t tab2 = tab1 == std::string::npos ? tab1 : line.find('\t', tab1 + 1);
+        if (tab1 == std::string::npos || tab2 == std::string::npos) continue;
+
+        GUIWlanList::WlanItem item;
+        item.network_id = line.substr(0, tab1);
+        item.ssid = decode_hex_escaped(line.substr(tab1 + 1, tab2 - tab1 - 1));
+        if (item.ssid.empty()) continue;
+        item.signal = "";
+        item.encryption = "Saved";
+        item.saved = true;
+        item.selected = false;
+        wlanList.push_back(item);
+    }
+
+    SetWlanList(wlanList);
+    DataManager::SetValue("tw_wlan_saved_count", std::to_string(wlanList.size()));
+    DataManager::SetValue("tw_wlan_list_update", "0");
+    DataManager::SetValue("tw_wlan_list_update", "1");
+    if (wlanList.empty()) {
+        DataManager::SetValue("tw_selected_wlan", "");
+        DataManager::SetValue("tw_selected_wlan_id", "");
+        DataManager::SetValue("tw_selected_wlan_saved", "0");
+        if (logBox) logBox->AddLogLine("[INFO] No saved WLAN networks", "normal");
+    }
+    gui_forceRender();
+    return 0;
+}
+
+int GUIAction::wlanforget(std::string arg __unused) {
+    GUIBorderedLogBox* logBox = FindWlanLogBox();
+    std::string network_id = DataManager::GetStrValue("tw_selected_wlan_id");
+    std::string ssid = DataManager::GetStrValue("tw_selected_wlan");
+    if (network_id.empty() || network_id.find_first_not_of("0123456789") != std::string::npos) {
+        if (logBox) logBox->AddLogLine("[ERROR] No saved WLAN network selected", "error");
+        gui_forceRender();
+        return -1;
+    }
+
+    std::string reply = run_command_get_output(
+            "wpa_cli -iwlan0 -p/tmp/recovery/sockets remove_network " + network_id);
+    if (reply.find("OK") == std::string::npos) {
+        if (logBox) logBox->AddLogLine("[ERROR] Failed to remove saved WLAN network", "error");
+        gui_forceRender();
+        return -1;
+    }
+    if (TWFunc::Exec_Cmd("/system/bin/nezha-wlan-control.sh save") != 0) {
+        if (logBox) logBox->AddLogLine("[ERROR] Removed network in memory, but failed to persist it", "error");
+        gui_forceRender();
+        return -1;
+    }
+
+    if (logBox) logBox->AddLogLine("[INFO] Forgot saved WLAN: " + ssid, "normal");
+    DataManager::SetValue("tw_selected_wlan", "");
+    DataManager::SetValue("tw_selected_wlan_id", "");
+    DataManager::SetValue("tw_selected_wlan_saved", "0");
+    wlanlistsaved("");
+    gui_forceRender();
+    return 0;
+}
