+static std::string shell_quote(const std::string& value) {
+    std::string quoted = "'";
+    for (char c : value) {
+        if (c == '\'') {
+            quoted += "'\\''";
+        } else {
+            quoted += c;
+        }
+    }
+    quoted += "'";
+    return quoted;
+}
+
+static std::string derive_wpa_psk(const std::string& ssid, const std::string& password) {
+    uint8_t psk[32];
+    if (!PKCS5_PBKDF2_HMAC_SHA1(password.c_str(), password.size(),
+            reinterpret_cast<const uint8_t*>(ssid.data()), ssid.size(), 4096,
+            sizeof(psk), psk)) {
+        return "";
+    }
+
+    std::ostringstream result;
+    result << std::hex << std::setfill('0');
+    for (uint8_t byte : psk) {
+        result << std::setw(2) << static_cast<unsigned int>(byte);
+    }
+    return result.str();
+}
